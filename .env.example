# AirAware Environment Template
# Copy this to .env and fill in your values
# WARNING: Never commit .env to git; it contains secrets!

# OpenWeatherMap API Configuration
OPENWEATHER_API_KEY=your_api_key_here

# Target Location
TARGET_CITY=New Delhi
TARGET_LAT=28.7041
TARGET_LON=77.1025

# Flask Configuration
PORT=5000
DEBUG=False

# Logging
LOG_LEVEL=INFO

# Database (if needed)
# DATABASE_URL=sqlite:///airaware.db

# Deployment (e.g., for Heroku)
# DEPLOYMENT_ENV=production
